# Copy this into a .env file with respective API keys
GOOGLE_CLOUD_PROJECT=gcp_project_id
# For local Docker: mount your key file and set the path, e.g.:
#   docker run -v /path/to/key.json:/secrets/key.json -e GOOGLE_APPLICATION_CREDENTIALS=/secrets/key.json ...
GOOGLE_APPLICATION_CREDENTIALS=path_for_gcp_service_account_key_json # the service account should have BigQuery Admin and Firebase Admin permissions

ORS_API=openrouteservice_api_key # https://openrouteservice.org/

ANTHROPIC_API_KEY=api_key # This is for API calls, not for Claude, Code, or Workspace. 
ANTHROPIC_LLM_MODEL=llm_model_name_version
ANTHROPIC_MAX_TOKENS=token_limit

CHATBOT_SUMMARY_THRESHOLD=messages_to_summarize
CHATBOT_HISTORY_LAST_TURNS=turns_to_persist

POSTGRES_INSTANCE_CONNECTION_NAME=your-project:region:instance
POSTGRES_HOST=/cloudsql/your-project:region:instance
POSTGRES_TCP_HOST=your-sql-instance-IP-address
CLOUDSQL_IP_TYPE=public
POSTGRES_PORT=5432
POSTGRES_DB=beacon
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
CLOUDSQL_IP_TYPE=public

# mem0 semantic memory (Qdrant Cloud + OpenAI embeddings)
QDRANT_URL=https://your-cluster.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key
OPENAI_API_KEY=your_openai_api_key  